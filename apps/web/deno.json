{
  "name": "@workspace/web",
  "version": "0.1.0",
  "exports": "./src/main.tsx",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "npm:@types/react@^19.2",
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "imports": {
    "@shared/mod": "../../packages/shared/mod.ts",
    "react": "npm:react@^19.2.4",
    "react-dom": "npm:react-dom@^19.2.4",
    "react-dom/client": "npm:react-dom@^19.2.4/client",
    "react/jsx-runtime": "npm:react@^19.2.4/jsx-runtime",
    "vite": "npm:vite@^7.3.1",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^5.1.4"
  },
  "tasks": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build"
  }
}
